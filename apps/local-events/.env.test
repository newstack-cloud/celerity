## Redis — uses the same env var as production (config.RedisURL).
CELERITY_LOCAL_REDIS_URL=redis://localhost:16379

## DynamoDB Local — no production env var (comes from config file);
## test-specific override for integration tests.
TEST_DYNAMODB_ENDPOINT=http://localhost:18000

## MinIO — no production env var (comes from config file);
## test-specific overrides for integration tests.
TEST_MINIO_ENDPOINT=http://localhost:19000
TEST_MINIO_ACCESS_KEY=minioadmin
TEST_MINIO_SECRET_KEY=minioadmin
